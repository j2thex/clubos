NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-start>
JWT_SECRET=clubos-dev-secret-change-in-production-min32
CONTACT_INBOX_EMAIL=hello@osocios.club
NEXT_PUBLIC_WHATSAPP_NUMBER=34600000000

# --- AI assist (Phase 0) ---
# Gateway auth: prefer `vercel env pull .env.local` which provisions
# VERCEL_OIDC_TOKEN automatically. AI_GATEWAY_API_KEY is the static fallback
# for non-Vercel environments (CI, local dev without `vercel link`).
AI_GATEWAY_API_KEY=<optional-static-gateway-key>
# AES-256-GCM master key for encrypting per-club BYOK provider keys (Phase 6).
# Any long random string works — it is hashed to 32 bytes before use.
AI_ENCRYPTION_KEY=<long-random-string-min-32-chars>
